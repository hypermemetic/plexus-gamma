{
  "schema": "1.0",
  "language": "typescript",
  "backend": "substrate",
  "url": "ws://127.0.0.1:4444",
  "packageManager": "bun",
  "watch": {
    "pollInterval": 1000,
    "hotReload": false
  },
  "targets": {
    "plexus": {
      "generate": ["transport", "rpc", "plugins"],
      "transport": "browser",
      "outputDir": "src/lib/plexus"
    }
  }
}
